
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS PERMISIVAS PARA LA DEMO SIBF - CAI
    // Permite lectura y escritura a cualquier usuario autenticado (incluyendo anónimos)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
