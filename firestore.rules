
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir todo a usuarios autenticados para la demo SIBF - CAI
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Permitir lectura de perfiles de usuario por matrícula para el login
    match /users/{userId} {
      allow read: if true;
    }
  }
}
