
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the UniAttend system.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string" },
        "password": { "type": "string" },
        "sedeId": { "type": "string" },
        "carreraId": { "type": "string" },
        "grupoId": { "type": "string", "description": "Used for Alumnos (single group)" },
        "grupoIds": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Used for Docentes (multiple groups)"
        },
        "matricula": { "type": "string" },
        "faceDescriptor": { 
          "type": "array", 
          "items": { "type": "number" },
          "description": "Biometric facial features (128 values)"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "firstName", "lastName", "role"]
    },
    "Sede": {
      "title": "Sede",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "ubicacion": { "type": "string" }
      },
      "required": ["nombre"]
    },
    "Carrera": {
      "title": "Carrera",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "sedeId": { "type": "string" }
      },
      "required": ["nombre", "sedeId"]
    },
    "Materia": {
      "title": "Materia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "codigo": { "type": "string" },
        "carreraId": { "type": "string" },
        "cuatrimestre": { "type": "string" }
      },
      "required": ["nombre", "carreraId", "cuatrimestre"]
    },
    "Grupo": {
      "title": "Grupo",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "carreraId": { "type": "string" },
        "cuatrimestre": { "type": "string" }
      },
      "required": ["nombre", "carreraId", "cuatrimestre"]
    },
    "Horario": {
      "title": "Horario",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "grupoId": { "type": "string" },
        "materiaId": { "type": "string" },
        "docenteId": { "type": "string" },
        "dia": { "type": "string", "enum": ["Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado"] },
        "horaInicio": { "type": "string" },
        "horaFin": { "type": "string" },
        "aula": { "type": "string" }
      },
      "required": ["grupoId", "dia", "horaInicio", "horaFin", "materiaId", "docenteId"]
    },
    "Asistencia": {
      "title": "Asistencia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "alumnoId": { "type": "string" },
        "docenteId": { "type": "string" },
        "grupoId": { "type": "string" },
        "materiaId": { "type": "string" },
        "fecha": { "type": "string", "format": "date" },
        "estado": { "type": "string", "enum": ["Presente", "Retraso", "Falta"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["alumnoId", "docenteId", "grupoId", "fecha", "estado"]
    },
    "Justificacion": {
      "title": "Justificacion",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "alumnoId": { "type": "string" },
        "docenteId": { "type": "string" },
        "fecha": { "type": "string", "format": "date" },
        "motivo": { "type": "string" },
        "estado": { "type": "string", "enum": ["Pendiente", "Aprobada", "Rechazada"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["alumnoId", "docenteId", "fecha", "motivo", "estado"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "User profiles" },
    "/sedes/{sedeId}": { "schema": { "$ref": "#/backend/entities/Sede" }, "description": "Campus locations" },
    "/carreras/{carreraId}": { "schema": { "$ref": "#/backend/entities/Carrera" }, "description": "Academic programs" },
    "/materias/{materiaId}": { "schema": { "$ref": "#/backend/entities/Materia" }, "description": "Subjects" },
    "/grupos/{grupoId}": { "schema": { "$ref": "#/backend/entities/Grupo" }, "description": "Class groups" },
    "/horarios/{horarioId}": { "schema": { "$ref": "#/backend/entities/Horario" }, "description": "Schedules" },
    "/asistencias/{asistenciaId}": { "schema": { "$ref": "#/backend/entities/Asistencia" }, "description": "Attendance records" },
    "/justificaciones/{justificacionId}": { "schema": { "$ref": "#/backend/entities/Justificacion" }, "description": "Student justifications" }
  }
}
